FROM python:3.11-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# EDA module is self-contained: includes its own data/raw/ copies
COPY eda/ eda/

EXPOSE 8501

# Run EDA pipeline to generate tables, then start Streamlit dashboard
CMD ["sh", "-c", "python -m eda.scripts.run_eda && streamlit run eda/app/Home.py --server.port=8501 --server.address=0.0.0.0 --server.headless=true"]
